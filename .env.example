# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Alternative: Use Ollama for local AI (no API key needed)
# Set USE_LOCAL_AI=true to use Ollama instead of Gemini
USE_LOCAL_AI=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Application Configuration
FLASK_ENV=development
PORT=5000

# Security (REQUIRED in production - generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_with_a_strong_random_secret_key

# Database (defaults to SQLite for local dev)
DATABASE_URL=sqlite:///shieldops.db
